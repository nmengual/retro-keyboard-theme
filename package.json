  },
  "author": {
    "name": "Nicolás Mengual"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "color-theme",
    "retro",
    "keyboard",
    "pastel",
    "warm",
    "mechanical-keyboard",
    "dark-theme",
    "light-theme"
  ],
  "galleryBanner": {
    "color": "#2A2520",
    "theme": "dark"
  },
  "contributes": {
    "themes": [
      {
        "label": "Retro Keyboard Dark",
