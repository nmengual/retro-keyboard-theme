  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7A6E5E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#3E8A5E"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#A86828"
      }
    },
    {
      "name": "Built-in constants",
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#C04040"
      }
    },
    {
      "name": "Other constants",
      "scope": ["constant.other", "constant.character"],
      "settings": {
        "foreground": "#A86828"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C04040"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation.separator"],
      "settings": {
        "foreground": "#6A5E4E"
      }
    },
    {
      "name": "Comparison & Assignment Operators",
      "scope": [
        "keyword.operator.comparison",
        "keyword.operator.assignment",
        "keyword.operator.relational",
        "keyword.operator.ternary",
        "keyword.operator.spread"
      ],
      "settings": {
        "foreground": "#A83838"
      }
    },
    {
      "name": "Arithmetic Operators",
      "scope": [
        "keyword.operator.arithmetic",
        "keyword.operator.increment",
        "keyword.operator.decrement"
      ],
      "settings": {
        "foreground": "#A86828"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#2E6E8A"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#8A6A10"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#8A6A10"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#3A8A80"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#3A6A7A"
      }
    },
    {
      "name": "Variable constants",
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": {
        "foreground": "#9A5520"
      }
    },
    {
      "name": "Variable properties",
      "scope": ["variable.other.property", "variable.other.object.property"],
      "settings": {
        "foreground": "#5A5E90"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#A86828"
      }
    },
    {
      "name": "Variable readwrite alias",
      "scope": ["variable.other.readwrite", "variable.other.readwrite.alias"],
      "settings": {
        "foreground": "#3A6A7A"
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#7E5EAA"
      }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#C04040"
      }
    },
    {
      "name": "Tag attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#A86828"
      }
    },
    {
      "name": "CSS selectors",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css"],
      "settings": {
        "foreground": "#8A6A10"
      }
    },
    {
      "name": "CSS property names",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#2E6E8A"
      }
    },
    {
      "name": "CSS values",
      "scope": ["support.constant.property-value.css"],
      "settings": {
        "foreground": "#3E8A5E"
      }
    },
    {
      "name": "CSS units",
      "scope": ["keyword.other.unit.css"],
      "settings": {
        "foreground": "#A86828"
      }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#7E5EAA"
      }
    },
    {
      "name": "Escape characters",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#3A8A80"
      }
    },
    {
      "name": "Punctuation brackets",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#6E5E90"
      }
    },
    {
      "name": "Punctuation accessor (dots)",
      "scope": ["punctuation.accessor", "punctuation.accessor.optional"],
      "settings": {
        "foreground": "#7A6E5E"
      }
    },
    {
      "name": "Punctuation semicolons commas",
      "scope": ["punctuation.terminator", "punctuation.separator.comma"],
      "settings": {
        "foreground": "#8A7E6E"
      }
    },
    {
      "name": "Import/Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#7E5EAA"
      }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#2E6E8A"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "heading.1.markdown",
        "heading.2.markdown",
        "heading.3.markdown",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#C04040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#A86828",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#7E5EAA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#2E6E8A"
      }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#3E8A5E"
      }
    },
    {
      "name": "PHP tags",
      "scope": ["punctuation.section.embedded.begin.php", "punctuation.section.embedded.end.php"],
      "settings": {
        "foreground": "#C04040"
      }
    },
    {
      "name": "this/self",
      "scope": ["variable.language.this", "variable.language.self"],
      "settings": {
        "foreground": "#A86828",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Namespace",
      "scope": ["entity.name.namespace", "entity.name.type.namespace"],
      "settings": {
        "foreground": "#8A6A10"
      }
    },
    {
      "name": "Template string expressions",
      "scope": ["punctuation.definition.template-expression"],
      "settings": {
        "foreground": "#C04040"
      }
    },
    {
      "name": "Support modules",
      "scope": ["support.module", "support.other.module"],
      "settings": {
        "foreground": "#8A6A10"
      }
    },
    {
      "name": "Support constants",
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#9A5520"
      }
    },
    {
      "name": "Keyword return/yield/await",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#A83838",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object keys",
      "scope": ["meta.object-literal.key", "variable.other.object.property"],
      "settings": {
        "foreground": "#2E6E8A"
      }
    },
    {
      "name": "Arrow function",
      "scope": ["storage.type.function.arrow"],
      "settings": {
        "foreground": "#A83838"
      }
    },
    {
      "name": "Type annotation punctuation",
      "scope": [
        "punctuation.definition.typeparameters",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#3A8A80"
      }
    },
    {
      "name": "String interpolation expressions",
      "scope": ["meta.template.expression"],
      "settings": {
        "foreground": "#3D3529"
      }
    },
    {
      "name": "Destructuring",
      "scope": ["meta.object-binding-pattern-variable", "meta.array-binding-pattern-variable"],
      "settings": {
        "foreground": "#3A6A7A"
      }
    },
    {
      "name": "Python - Self parameter",
      "scope": ["variable.parameter.function.language.special.self.python"],
      "settings": {
        "foreground": "#A86828",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python - Magic methods",
      "scope": ["support.function.magic.python"],
      "settings": {
        "foreground": "#2E6E8A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python - Decorators",
      "scope": ["entity.name.function.decorator.python"],
      "settings": {
        "foreground": "#7E5EAA"
      }
    },
    {
      "name": "Python - F-string expressions",
      "scope": ["meta.fstring.python"],
      "settings": {
        "foreground": "#3D3529"
      }
    },
    {
      "name": "Rust - Lifetime",
      "scope": ["storage.modifier.lifetime.rust", "entity.name.type.lifetime.rust"],
      "settings": {
        "foreground": "#3A8A80",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust - Macros",
      "scope": ["entity.name.function.macro.rust", "support.macro.rust"],
      "settings": {
        "foreground": "#C04040"
      }
    },
    {
      "name": "Rust - Traits",
      "scope": ["entity.name.type.trait.rust"],
      "settings": {
        "foreground": "#3A8A80"
      }
    },
    {
      "name": "Rust - Attribute",
      "scope": ["meta.attribute.rust"],
      "settings": {
        "foreground": "#7E5EAA"
      }
    },
    {
      "name": "Go - Package name",
      "scope": ["entity.name.package.go"],
      "settings": {
        "foreground": "#8A6A10"
      }
    },
    {
      "name": "Go - Builtin functions",
      "scope": ["support.function.builtin.go"],
      "settings": {
        "foreground": "#3A6A7A"
      }
    },
    {
      "name": "Shell - Variables",
