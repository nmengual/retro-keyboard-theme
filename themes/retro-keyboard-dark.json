  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#8A7E6E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#8BBF9C"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#D4854A"
      }
    },
    {
      "name": "Built-in constants",
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#E06060"
      }
    },
    {
      "name": "Other constants",
      "scope": ["constant.other", "constant.character"],
      "settings": {
        "foreground": "#D4854A"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E06060"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation.separator"],
      "settings": {
        "foreground": "#ACA395"
      }
    },
    {
      "name": "Comparison & Assignment Operators",
      "scope": [
        "keyword.operator.comparison",
        "keyword.operator.assignment",
        "keyword.operator.relational",
        "keyword.operator.ternary",
        "keyword.operator.spread"
      ],
      "settings": {
        "foreground": "#F07878"
      }
    },
    {
      "name": "Arithmetic Operators",
      "scope": [
        "keyword.operator.arithmetic",
        "keyword.operator.increment",
        "keyword.operator.decrement"
      ],
      "settings": {
        "foreground": "#E8A860"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#8AAEC4"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E8C060"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#E8C060"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#88CCC0"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#A8C8DC"
      }
    },
    {
      "name": "Variable constants",
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": {
        "foreground": "#E8A860"
      }
    },
    {
      "name": "Variable properties",
      "scope": ["variable.other.property", "variable.other.object.property"],
      "settings": {
        "foreground": "#C0B0E0"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#D4854A"
      }
    },
    {
      "name": "Variable readwrite alias",
      "scope": ["variable.other.readwrite", "variable.other.readwrite.alias"],
      "settings": {
        "foreground": "#A8C8DC"
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#B89ED6"
      }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#E06060"
      }
    },
    {
      "name": "Tag attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#D4854A"
      }
    },
    {
      "name": "CSS selectors",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css"],
      "settings": {
        "foreground": "#E8C060"
      }
    },
    {
      "name": "CSS property names",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#8AAEC4"
      }
    },
    {
      "name": "CSS values",
      "scope": ["support.constant.property-value.css"],
      "settings": {
        "foreground": "#8BBF9C"
      }
    },
    {
      "name": "CSS units",
      "scope": ["keyword.other.unit.css"],
      "settings": {
        "foreground": "#D4854A"
      }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#B89ED6"
      }
    },
    {
      "name": "Escape characters",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#88CCC0"
      }
    },
    {
      "name": "Punctuation brackets",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#C0A8E0"
      }
    },
    {
      "name": "Punctuation accessor (dots)",
      "scope": ["punctuation.accessor", "punctuation.accessor.optional"],
      "settings": {
        "foreground": "#ACA395"
      }
    },
    {
      "name": "Punctuation semicolons commas",
      "scope": ["punctuation.terminator", "punctuation.separator.comma"],
      "settings": {
        "foreground": "#7A6E5E"
      }
    },
    {
      "name": "Import/Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#B89ED6"
      }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#8AAEC4"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "heading.1.markdown",
        "heading.2.markdown",
        "heading.3.markdown",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#E06060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#D4854A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#B89ED6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#8AAEC4"
      }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#8BBF9C"
      }
    },
    {
      "name": "PHP tags",
      "scope": ["punctuation.section.embedded.begin.php", "punctuation.section.embedded.end.php"],
      "settings": {
        "foreground": "#E06060"
      }
    },
    {
      "name": "this/self",
      "scope": ["variable.language.this", "variable.language.self"],
      "settings": {
        "foreground": "#D4854A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Namespace",
      "scope": ["entity.name.namespace", "entity.name.type.namespace"],
      "settings": {
        "foreground": "#E8C060"
      }
    },
    {
      "name": "Template string expressions",
      "scope": ["punctuation.definition.template-expression"],
      "settings": {
        "foreground": "#E06060"
      }
    },
    {
      "name": "Support modules",
      "scope": ["support.module", "support.other.module"],
      "settings": {
        "foreground": "#E8C060"
      }
    },
    {
      "name": "Support constants",
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#E8A860"
      }
    },
    {
      "name": "Keyword return/yield/await",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#F07878",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object keys",
      "scope": ["meta.object-literal.key", "variable.other.object.property"],
      "settings": {
        "foreground": "#8AAEC4"
      }
    },
    {
      "name": "Arrow function",
      "scope": ["storage.type.function.arrow"],
      "settings": {
        "foreground": "#F07878"
      }
    },
    {
      "name": "Type annotation punctuation",
      "scope": [
        "punctuation.definition.typeparameters",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#88CCC0"
      }
    },
    {
      "name": "String interpolation expressions",
      "scope": ["meta.template.expression"],
      "settings": {
        "foreground": "#EDE4D6"
      }
    },
    {
      "name": "Destructuring",
      "scope": ["meta.object-binding-pattern-variable", "meta.array-binding-pattern-variable"],
      "settings": {
        "foreground": "#A8C8DC"
      }
    },
    {
      "name": "Python - Self parameter",
